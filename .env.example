# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# Email config
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="KAST'ASSO"

# Base de données config
DB_PORT=3306
DB_CHARSET=utf8mb4

# Contact
CONTACT_EMAIL=

# Rate limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# IMPORTANT : Les credentials (mots de passe, utilisateurs DB, etc.)
# ne sont PAS dans ce fichier. Ils doivent être placés dans le dossier
# secrets/ (voir README pour la procédure).
